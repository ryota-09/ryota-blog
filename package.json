{
  "name": "ryota-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "NODE_ENV=development velite build && node scripts/generate-font-subset.mjs",
    "dev": "concurrently -n velite,next -c blue,green \"NODE_ENV=development velite dev --watch\" \"next dev -p 3006\"",
    "prebuild": "NODE_ENV=production velite build && node scripts/generate-font-subset.mjs",
    "subset-font": "node scripts/generate-font-subset.mjs",
    "build": "next build",
    "analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "lint": "eslint .",
    "pretest": "NODE_ENV=development velite build",
    "test": "vitest",
    "new-post": "node scripts/new-post.mjs",
    "optimize-images": "node scripts/migration/optimize-images.mjs",
    "lint:content": "node scripts/check-internal-links.mjs && npx textlint \"content/blogs/**/index.ja.mdx\" && npx markdownlint-cli2 \"content/blogs/**/index.*.mdx\" && npx velite build",
    "e2e": "npx playwright test",
    "e2e:dev": "./run-e2e-tests.sh",
    "e2e:serve": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/ && PORT=3001 node .next/standalone/server.js",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "NODE_ENV=development velite build",
    "build-storybook": "storybook build",
    "update-rss": "node ./src/static/rss/rss-parser.js",
    "preview:stg": "opennextjs-cloudflare build --config wrangler.stg.jsonc && opennextjs-cloudflare preview --config wrangler.stg.jsonc",
    "preview:prd": "opennextjs-cloudflare build --config wrangler.prd.jsonc && opennextjs-cloudflare preview --config wrangler.prd.jsonc",
    "deploy:stg": "opennextjs-cloudflare build --config wrangler.stg.jsonc && opennextjs-cloudflare deploy --config wrangler.stg.jsonc",
    "deploy:prd": "opennextjs-cloudflare build --config wrangler.prd.jsonc && opennextjs-cloudflare deploy --config wrangler.prd.jsonc",
    "update-lh:desktop": "lhci autorun --config=.desktop-lighthouserc.js",
    "update-lh:mobile": "lhci autorun --config=.mobile-lighthouserc.js && node ./webvitals/update-mobile-vitals.js",
    "cf-typegen": "wrangler types --config wrangler.stg.jsonc"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "feed": "^4.2.2",
    "html-react-parser": "^5.1.10",
    "lucide-react": "^0.439.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "next-view-transitions": "^0.1.1",
    "nextjs-toploader": "^1.6.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scroll": "^1.9.0",
    "react-syntax-highlighter": "^15.5.0",
    "react-tweet": "^3.3.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^1.5.0",
    "@mdx-js/mdx": "^3.1.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/addon-links": "8.6.18",
    "@storybook/addon-mdx-gfm": "8.6.18",
    "@storybook/addon-onboarding": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/react-scroll": "^1.8.10",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^9.1.0",
    "hast-util-to-mdast": "^10.1.2",
    "js-yaml": "^4.3.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^13.4.0",
    "markdownlint-cli2": "^0.23.0",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-markdown": "^2.1.2",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.17",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.1",
    "rehype-parse": "^9.0.1",
    "rss-parser": "^3.13.0",
    "schema-dts": "^1.1.2",
    "sharp": "0.32.6",
    "storybook": "8.6.18",
    "subset-font": "^2.5.0",
    "tailwindcss": "^3.4.1",
    "textlint": "^15.7.1",
    "textlint-plugin-mdx": "^1.1.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "velite": "^0.4.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "prismjs": "^1.30.0",
    "postcss": "^8.5.17"
  }
}

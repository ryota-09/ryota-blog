/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Velite出力の記事画像(コンテンツハッシュ付きファイル名のため実質immutable)。
# OpenNextの画像最適化ハンドラは元画像のCache-Controlにimmutableが含まれる場合のみ
# /_next/image レスポンスに長期Cache-Controlを付与するため、このルールが
# ブラウザ/CDNでの画像キャッシュ有効化の前提になる(Issue #220)
/static/*
  Cache-Control: public, max-age=31536000, immutable

# 著者アイコン(全記事ページで/_next/image経由で参照される)。
# 変更時はファイル名の変更(キャッシュバスト)が必要
/author.png
  Cache-Control: public, max-age=31536000, immutable

/*.ttf
  Cache-Control: public, max-age=31536000, immutable

# フォント@font-face定義CSS(ファイル名にバージョンを含むため実質immutable。更新時はファイル名変更)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=86400

# favicon.ico(app/favicon.ico規約が静的アセットとして配信)。ブラウザ/検索エンジンが
# <link>と無関係にデフォルトで叩く定番URLで、Googleのfaviconフェッチャーが最優先で参照する。
# デフォルトの max-age=0, must-revalidate だと毎回再検証されるため、検索エンジンの
# favicon再評価を安定させる目的で1日キャッシュを付与する。再デザイン時は1日以内に伝播する。
# NOTE: /icon.png・/apple-icon.png はNext.jsのメタデータ・ワーカールートで配信され
# _headersが適用されない(静的アセットではない)ため、ここでは指定しない。favicon.icoが
# 主経路になるので実害はない
/favicon.ico
  Cache-Control: public, max-age=86400
